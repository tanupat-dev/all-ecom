includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/pestphp/pest/phpstan-pest-extension.neon

parameters:
    level: max
    # PHPDoc generics declare intent (e.g. MoneyCast accepts Money), but runtime
    # fail-loud guards behind them must not be flagged "always true".
    treatPhpDocTypesAsCertain: false
    paths:
        - app
        - config
        - database
        - routes
        - tests
    excludePaths:
        # Vendor-authored stub published by spatie/laravel-permission —
        # third-party code, not held to this repo's level-max bar.
        - database/migrations/2026_06_12_055941_create_permission_tables.php
